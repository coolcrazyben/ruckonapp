{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run db:push)",
      "Bash(npm run db:studio)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff HEAD~1)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git merge feature/*)",
      "Bash(git push origin feature/*)",
      "Bash(git worktree add *)",
      "Bash(git worktree remove *)"
    ],
    "deny": [
      "Read(./.env*)",
      "Read(./secrets/**)",
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push origin main:*)"
    ]
  }
}
